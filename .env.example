# Server-side only. Use this only if LI.FI requires an API key for your account/tier.
LIFI_API_KEY=

# Optional LI.FI base URL override.
NEXT_PUBLIC_LIFI_API_BASE=https://li.quest/v1

# Optional explorer/RPC overrides should stay in server or deployment envs, not hardcoded secrets.

# Optional public Sui RPC override. Leave blank to use Mysten's public mainnet fullnode.
NEXT_PUBLIC_SUI_RPC_URL=

# Optional Human Wallet referral code override. Defaults to "boPYvnaw6J5gHgbv".
# Passed as a TOP-LEVEL field to initWaaP / initWaaPSui (sibling of config,
# not nested inside it) so onboarding attribution credits the right account.
NEXT_PUBLIC_WAAP_REFERRAL_CODE=
