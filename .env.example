# Server-side only. Use this only if LI.FI requires an API key for your account/tier.
LIFI_API_KEY=

# Optional LI.FI base URL override.
NEXT_PUBLIC_LIFI_API_BASE=https://li.quest/v1

# Optional explorer/RPC overrides should stay in server or deployment envs, not hardcoded secrets.

